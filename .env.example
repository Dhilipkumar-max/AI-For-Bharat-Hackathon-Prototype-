# AI Vidya for Bharat - Environment Variables

# ============================================
# Backend Configuration
# ============================================

# YouTube Data API
# Get API key from: https://console.cloud.google.com
# 1. Create new project
# 2. Enable "YouTube Data API v3"
# 3. Create API key under Credentials
YOUTUBE_API_KEY=your_youtube_api_key_her

# Database (if using external DB)
DATABASE_URL=mongodb://localhost:27017/ai-vidya-bharat

# Environment
NODE_ENV=development
PORT=3001

# API Configuration
API_VERSION=v1
API_TIMEOUT=30000

# ============================================
# Frontend Configuration
# ============================================

# API Base URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# YouTube API Key (if frontend calls directly)
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here

# Site Configuration
NEXT_PUBLIC_SITE_NAME=AI Vidya for Bharat
NEXT_PUBLIC_SITE_DESCRIPTION=AI-powered learning platform for Indian users
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Feature Flags
# ============================================

# Enable PWA
NEXT_PUBLIC_PWA_ENABLED=true

# Enable Offline Mode
NEXT_PUBLIC_OFFLINE_MODE=true

# Enable Video Integration
NEXT_PUBLIC_VIDEO_INTEGRATION=true

# Enable Analytics
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_ID=

# ============================================
# Development Only
# ============================================

# Debug mode
DEBUG=false
NEXT_PUBLIC_DEBUG=false

# Mock data (for testing without API)
NEXT_PUBLIC_USE_MOCK_DATA=false

# ============================================
# Production Only
# ============================================

# Security
SECURE_HEADERS_ENABLED=true
CORS_ORIGIN=https://yourdomain.com

# Error tracking (Sentry, etc.)
SENTRY_DSN=

# Performance monitoring
PERFORMANCE_MONITORING_ENABLED=true

# ============================================
# Optional Services
# ============================================

# Image hosting
NEXT_PUBLIC_IMAGE_HOST=https://images.yourdomain.com

# CDN
NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com

# ============================================
# Cache Configuration
# ============================================

# Service Worker cache version
NEXT_PUBLIC_CACHE_VERSION=v1

# Cache duration (in seconds)
NEXT_PUBLIC_CACHE_DURATION=3600

# ============================================
# Security Keys
# ============================================

# These should be long, random strings
# Generate with: openssl rand -base64 32
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here
